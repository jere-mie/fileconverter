---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'File Converter - Free, Private, Browser-Based',
  description = 'Convert files instantly in your browser. No uploads, no accounts, 100% private. Video, audio, image, and document conversion powered by WebAssembly.',
} = Astro.props;

const site = Astro.site ?? new URL('https://fileconverter.zxcv.fyi');
const canonicalUrl = new URL(`${Astro.url.pathname}${Astro.url.search}`, site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="File Converter" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline src="/coi-serviceworker.js"></script>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
  }
</style>
